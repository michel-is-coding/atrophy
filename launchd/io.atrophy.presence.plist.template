<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>io.atrophy.presence</string>
  <key>ProgramArguments</key>
  <array><string>/bin/bash</string><string>@ATROPHY_DIR@/bin/presence-poll.sh</string></array>
  <key>StartInterval</key><integer>60</integer>
  <key>RunAtLoad</key><true/>
  <key>EnvironmentVariables</key><dict><key>ATROPHY_HOME</key><string>@HOME@/.atrophy</string></dict>
  <key>StandardErrorPath</key><string>@HOME@/.atrophy/presence-cron.log</string>
</dict>
</plist>
